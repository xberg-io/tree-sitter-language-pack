{
	"id": "detect_ext_ruby",
	"description": "detect_language_from_extension recognizes .rb as ruby",
	"category": "language-detection",
	"tags": ["language-detection", "extension"],
	"call": "detect_extension",
	"input": {
		"extension": "rb"
	},
	"assertions": [
		{
			"type": "equals",
			"value": "ruby"
		}
	]
}
