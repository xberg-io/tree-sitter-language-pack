{
  "id": "download_multiple_languages",
  "description": "download(['python', 'rust']) returns count >= 2",
  "category": "download",
  "tags": ["download"],
  "call": "download_languages",
  "skip": {
    "languages": ["wasm"],
    "reason": "Download feature requires network access and is not available in static builds"
  },
  "input": {
    "languages": ["python", "rust"]
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "greater_than_or_equal",
      "value": 2
    }
  ]
}
