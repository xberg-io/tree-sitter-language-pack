{
  "id": "download_manifest_languages",
  "description": "List manifest languages and verify the full downloadable catalog",
  "category": "download",
  "tags": ["download"],
  "call": "manifest_languages",
  "skip": {
    "languages": ["wasm"],
    "reason": "Download feature requires network access and is not available in static builds"
  },
  "input": {},
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "not_empty"
    },
    {
      "type": "count_min",
      "value": 300
    },
    {
      "type": "contains",
      "value": "python"
    }
  ]
}
