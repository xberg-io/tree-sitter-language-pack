*.test
bin/
# The dart package ships `bin/download_libs.dart` as its `pubspec executables:`
# entry that consumers run after `pub get` to fetch the platform-specific native
# library. Without re-including this path, `git ls-files` and `actions/checkout`
# omit the file and `pub publish` ships a pubspec referencing a missing
# executable — and `dart run <pkg>:download_libs` fails on every consumer.
!packages/dart/bin/
!packages/dart/bin/**
# The cli-proxy npm package ships `bin/ts-pack.js` as its `package.json` `bin`
# launcher (downloads + execs the native ts-pack binary). The generic `bin/`
# rule above would otherwise drop it and publish a package with no executable.
!cli-proxy/npm/bin/
!cli-proxy/npm/bin/**
obj/
*.nupkg

e2e/zig/.zig-cache/
test_apps/zig/.zig-cache/
test_apps/zig/zig-pkg/
test_apps/swift_e2e/Package.resolved
# Root Package.resolved is a local SPM resolution artifact for the published root
# manifest — not consumed downstream (SPM ignores a dependency's Package.resolved).
/Package.resolved
# swift-bridge generated sources MUST be tracked: SPM consumers checking out
# the git tag don't run cargo build, so without these files in the tree the
# RustString type defined here is missing → ZSwiftPluginHelpers.swift won't
# compile. Regenerated on each rc cut via `cargo build -p tree-sitter-language-pack-swift`.
e2e/dart/.dart_tool/

test_apps/c/ffi/
e2e/c/ffi/

.ai-rulez/.generated-manifest.json

packages/zig/zig-pkg/
e2e/zig/zig-pkg/


