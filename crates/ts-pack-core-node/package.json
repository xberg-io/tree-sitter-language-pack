{
  "name": "@kreuzberg/tree-sitter-language-pack",
  "version": "1.9.0-rc.25",
  "description": "Pre-compiled tree-sitter grammars for 306 programming languages",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kreuzberg-dev/tree-sitter-language-pack.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": ["index.js", "index.d.ts", "*.node"],
  "optionalDependencies": {
    "@kreuzberg/tree-sitter-language-pack-linux-x64-gnu": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-linux-arm64-gnu": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-linux-x64-musl": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-linux-arm64-musl": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-darwin-x64": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-darwin-arm64": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-win32-x64-msvc": "1.9.0-rc.25",
    "@kreuzberg/tree-sitter-language-pack-win32-arm64-msvc": "1.9.0-rc.25"
  },
  "napi": {
    "packageName": "@kreuzberg/tree-sitter-language-pack",
    "binaryName": "ts-pack-core-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
    "artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
    "prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
  },
  "engines": { "node": ">= 18" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@napi-rs/cli": "^3.6.2" }
}
