{
  "name": "@kreuzberg/tree-sitter-language-pack",
  "version": "1.8.0-rc.25",
  "description": "Pre-compiled tree-sitter grammars for 305 programming languages",
  "keywords": [
    "language-pack",
    "parser",
    "syntax",
    "tree-sitter"
  ],
  "license": "MIT",
  "author": "Kreuzberg Team",
  "repository": "https://github.com/kreuzberg-dev/tree-sitter-language-pack",
  "files": [
    "index.js",
    "index.d.ts",
    "**/*.node"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --release",
    "build:debug": "napi build",
    "build:ts": "echo 'No TypeScript wrapper to build'",
    "test": "node -e \"console.log('Add test command')\""
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "napi": {
    "name": "tree-sitter-language-pack",
    "triples": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  }
}
