{
	"name": "@kreuzberg/tree-sitter-language-pack",
	"version": "1.8.0-rc.26",
	"description": "Pre-compiled tree-sitter grammars for 305 programming languages",
	"license": "MIT",
	"main": "index.js",
	"types": "index.d.ts",
	"repository": "https://github.com/kreuzberg-dev/tree-sitter-language-pack",
	"author": "Kreuzberg Team",
	"keywords": [
		"tree-sitter",
		"parser",
		"syntax",
		"language-pack"
	],
	"files": [
		"index.js",
		"index.d.ts",
		"**/*.node"
	],
	"scripts": {
		"build": "napi build --release",
		"build:debug": "napi build",
		"build:ts": "echo 'No TypeScript wrapper to build'",
		"test": "node -e \"console.log('Add test command')\"",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
	"napi": {
		"name": "tree-sitter-language-pack",
		"triples": [
			"x86_64-unknown-linux-gnu",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.0.0",
		"oxfmt": "latest",
		"oxlint": "latest",
		"typescript": "^6.0.3"
	}
}
